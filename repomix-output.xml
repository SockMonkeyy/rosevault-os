          {userInitial}
        </div>
      </header>

      {/* Metrics Section with Interactive Clickable Card Micro-Elevation */}
      <div className="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-4">
        {metrics.map(([label, value]) => (
          <div
